# =============================================
# RAG Expert System (Gemini) - Konfigurasi
# =============================================

# Google Gemini API Key (WAJIB DIISI)
# Dapatkan gratis di: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=isi_api_key_kamu_di_sini

# Model Gemini yang digunakan
# Pilihan: gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# Embedding Model (berjalan lokal, tidak perlu internet setelah download)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB - lokasi penyimpanan vector database
CHROMA_PERSIST_DIR=./vectorstore
CHROMA_COLLECTION_NAME=rag_documents

# Chunking - ukuran potongan dokumen
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Retrieval - jumlah dokumen relevan yang diambil per pertanyaan
TOP_K_RESULTS=5
